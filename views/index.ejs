<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a1022" />
    <title>Binance Futures Charts</title>

    <!-- Lightweight Charts -->
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
        integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>

    <!-- Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Syne:wght@500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/style.css?v=20260216-radar-v4">
</head>

<body class="h-screen overflow-hidden bg-[#090f1f] text-white antialiased">
    <a id="skipToChartsLink" href="#mainContent"
        class="skip-link sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:rounded-lg focus:bg-white focus:px-3 focus:py-2 focus:text-sm focus:font-bold focus:text-slate-900">Skip
        to charts</a>

    <!-- Background glow -->
    <div id="globalBackdrop" class="pointer-events-none fixed inset-0 -z-10">
        <div class="absolute -top-32 -left-24 h-[620px] w-[620px] rounded-full bg-cyan-400/12 blur-3xl"></div>
        <div class="absolute -top-24 -right-20 h-[560px] w-[560px] rounded-full bg-amber-300/12 blur-3xl"></div>
        <div class="absolute -bottom-48 left-1/2 h-[640px] w-[640px] -translate-x-1/2 rounded-full bg-sky-500/10 blur-3xl">
        </div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(10,132,255,0.08),transparent_46%),radial-gradient(circle_at_18%_82%,rgba(245,158,11,0.08),transparent_42%)]"></div>
        <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(148,163,184,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(148,163,184,0.05)_1px,transparent_1px)] bg-[size:44px_44px] opacity-[0.16]"></div>
    </div>

    <div class="app-shell flex h-screen overflow-hidden">
        <!-- Tool rail -->
        <aside id="toolRail" aria-label="Tool dock"
            class="shrink-0 border-r border-white/10 bg-slate-950/70 backdrop-blur-xl flex flex-col items-center justify-between py-3">
            <div class="w-full px-2">
                <div class="flex flex-col gap-2">
                    <button type="button" class="tool-rail-item active" data-panel="market" data-tooltip="Menu"
                        aria-label="Open menu panel" aria-controls="sidebar" aria-expanded="true" aria-pressed="true" title="Menu">
                        <svg aria-hidden="true" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 7h16M4 12h16M4 17h16" />
                        </svg>
                    </button>

                    <button type="button" class="tool-rail-item" data-panel="tools" data-tooltip="Tools"
                        aria-label="Open tools panel"
                        aria-controls="sidebar" aria-expanded="false" aria-pressed="false" title="Tools">
                        <svg aria-hidden="true" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M9.75 3a2.25 2.25 0 00-2.12 1.5l-.34 1.02a2.25 2.25 0 01-1.42 1.42l-1.02.34A2.25 2.25 0 003 9.75v.5a2.25 2.25 0 001.5 2.12l1.02.34a2.25 2.25 0 011.42 1.42l.34 1.02A2.25 2.25 0 009.75 18h.5a2.25 2.25 0 002.12-1.5l.34-1.02a2.25 2.25 0 011.42-1.42l1.02-.34A2.25 2.25 0 0018 10.25v-.5a2.25 2.25 0 00-1.5-2.12l-1.02-.34a2.25 2.25 0 01-1.42-1.42l-.34-1.02A2.25 2.25 0 0010.25 3h-.5z" />
                            <circle cx="10" cy="10" r="2.2" />
                        </svg>
                    </button>

                    <button type="button" class="tool-rail-item" data-panel="layout" data-tooltip="Settings"
                        aria-label="Open settings panel"
                        aria-controls="sidebar" aria-expanded="false" aria-pressed="false" title="Settings">
                        <svg aria-hidden="true" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M10.325 4.317a1.724 1.724 0 013.35 0 1.724 1.724 0 002.573 1.066 1.724 1.724 0 012.904 1.675 1.724 1.724 0 001.066 2.573 1.724 1.724 0 010 3.35 1.724 1.724 0 00-1.066 2.573 1.724 1.724 0 01-2.904 1.675 1.724 1.724 0 00-2.573 1.066 1.724 1.724 0 01-3.35 0 1.724 1.724 0 00-2.573-1.066 1.724 1.724 0 01-2.904-1.675 1.724 1.724 0 00-1.066-2.573 1.724 1.724 0 010-3.35 1.724 1.724 0 001.066-2.573 1.724 1.724 0 012.904-1.675 1.724 1.724 0 002.573-1.066z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </button>
                </div>
            </div>

            <div id="dockLabel" class="text-[10px] font-semibold uppercase tracking-wider text-slate-500">Dock</div>
        </aside>

        <%- include('partials/sidebar') %>

            <main id="mainContent" class="relative flex-1 min-w-0">
                <div
                    class="main-topbar relative z-40 overflow-visible h-[68px] border-b border-white/10 bg-slate-950/45 backdrop-blur-xl px-4 md:px-6 flex items-center justify-between">
                    <div class="min-w-0">
                        <h1 id="topbarTitle" class="topbar-title text-sm md:text-base font-semibold tracking-tight text-white/90">Futures Radar</h1>
                        <p id="topbarSubtitle" class="text-[11px] md:text-xs text-slate-400">Realtime Binance perpetual watchboard</p>
                    </div>

                    <div class="relative w-[180px] sm:w-[240px] md:w-[340px]">
                        <label id="coinSearchLabel" for="coinSearch" class="sr-only">Search symbol</label>
                        <input id="coinSearch" name="coinSearch" type="text" autocomplete="off" spellcheck="false"
                            placeholder="Search symbol to auto-render charts…"
                            class="w-full rounded-xl border border-white/15 bg-slate-900/70 px-9 py-2 text-xs text-white/90
                            placeholder:text-slate-400 outline-none focus:border-cyan-300/55 focus:ring-2 focus:ring-cyan-300/20 transition-colors duration-200" />
                        <svg aria-hidden="true" class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-slate-400" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-4.35-4.35M10.5 18a7.5 7.5 0 100-15 7.5 7.5 0 000 15z" />
                        </svg>
                        <div id="coinSuggestDropdown"
                            class="hidden absolute left-0 right-0 top-[calc(100%+8px)] z-50 rounded-xl border border-white/10 bg-slate-900/95 p-1.5 backdrop-blur-xl shadow-2xl">
                        </div>
                    </div>

                    <div class="hidden lg:flex items-center gap-2 text-[10px] uppercase tracking-[0.14em] text-slate-400">
                        <span class="top-chip">Binance Futures</span>
                        <span class="top-chip">USDT Perp</span>
                        <span class="top-chip">Lightweight Charts</span>
                    </div>
                </div>

                <div id="staleNotice"
                    class="hidden absolute right-4 md:right-6 top-[72px] z-50 rounded-xl border border-amber-300/35 bg-slate-900/92 px-3 py-2 backdrop-blur-xl shadow-2xl">
                    <div class="flex items-center gap-3">
                        <div class="h-2 w-2 shrink-0 rounded-full bg-amber-300 shadow-[0_0_0_4px_rgba(252,211,77,0.18)]"></div>
                        <div id="staleNoticeText" class="text-[11px] text-amber-100">
                            Data may be stale for this timeframe.
                        </div>
                        <button id="reloadLatestBtn" type="button"
                            class="rounded-lg border border-amber-200/35 bg-amber-300/15 px-2.5 py-1 text-[11px] font-semibold text-amber-100 hover:bg-amber-300/25 hover:border-amber-200/55 transition-colors duration-200">
                            Load latest
                        </button>
                    </div>
                </div>

                <div id="chartGrid"
                    class="chart-stage relative z-10 h-[calc(100%-68px)] overflow-y-auto overflow-x-hidden p-4 md:p-6 flex flex-wrap gap-4 md:gap-5 content-start">
                    <div id="chartEmptyState" class="chart-empty-state w-full flex items-center justify-center rounded-2xl border border-white/10 p-12 text-slate-300 font-medium">
                        Pick symbols and press Render Charts
                    </div>
                </div>

                <div id="patternScanMainLoader" class="chart-scan-loader hidden" aria-live="polite" role="status" hidden>
                    <div class="chart-scan-loader-card">
                        <span class="chart-scan-spinner" aria-hidden="true"></span>
                        <div id="patternScanMainLoaderText" class="chart-scan-loader-text">Scanning pattern…</div>
                    </div>
                </div>
            </main>
    </div>

    <div id="statusLive" class="sr-only" aria-live="polite"></div>

    <!-- JS -->
    <!-- Custom Scripts -->
    <script src="/js/components/chart-component.js?v=20260216-radar-v4"></script>
    <script src="/js/chart.js?v=20260216-radar-v4"></script>
</body>

</html>
