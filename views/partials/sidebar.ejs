                <select id="settingTheme"
                    class="fancy-select settings-select w-full rounded-lg border border-white/15 bg-slate-800/60 px-2.5 py-2 text-xs text-slate-100 outline-none focus:border-cyan-300/55 focus:ring-2 focus:ring-cyan-300/20">
                    <option value="cyan">Neon Cyan</option>
                    <option value="amber">Solar Amber</option>
                    <option value="emerald">Neo Emerald</option>
