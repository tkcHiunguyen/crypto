                <button id="settingsResetBtn" type="button"
                    class="mt-2 w-full rounded-lg border border-white/10 bg-slate-800/45 px-2 py-2 text-xs font-semibold text-white/90 hover:bg-slate-700/65 hover:border-white/15 active:scale-[0.98] transition-colors duration-200">
                    Reset to defaults
                </button>
            </div>
        </section>
    </div>
