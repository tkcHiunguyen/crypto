                    </button>
                </div>

                <div id="patternCategoryChips" class="grid grid-cols-4 gap-1.5">
                    <button type="button" class="pattern-category-chip" data-pattern-category="All" aria-pressed="true">All</button>
                    <button type="button" class="pattern-category-chip" data-pattern-category="Bullish" aria-pressed="false">Bullish</button>
                    <button type="button" class="pattern-category-chip" data-pattern-category="Bearish" aria-pressed="false">Bearish</button>
                    <button type="button" class="pattern-category-chip" data-pattern-category="Neutral" aria-pressed="false">Neutral</button>
                </div>

                <div id="patternIconGrid" class="pattern-icon-grid mt-2" role="listbox" aria-label="Candlestick pattern icons">
                    <div class="pattern-grid-empty">Loading pattern icons…</div>
                </div>

                <select id="patternSelect" class="hidden" aria-hidden="true" tabindex="-1">
                    <option value="">Off</option>
